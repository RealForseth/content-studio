    "end": 13.0
  },
  {
    "text": "Ja, jeg valgte Karl",
    "start": 13.2,
    "end": 14.08
  },
  {
    "text": "Assistenten min, Karl.",
    "start": 14.08,
    "end": 15.52
  },
  {
    "text": "Jeg liker den, men",
